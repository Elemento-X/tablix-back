# ===========================================
# TABLIX BACKEND - ENVIRONMENT VARIABLES
# ===========================================
# Copie este arquivo para .env e preencha os valores

# Server
PORT=3333
NODE_ENV=development
API_URL="http://localhost:3333"

# ===========================================
# Database (Supabase PostgreSQL - São Paulo)
# ===========================================
# Pooler para queries da aplicação (porta 6543) - REQUER ?pgbouncer=true
# connection_limit: max connections Prisma abre ao pooler. Default ~num_cpus*2+1.
#   Calcular como: pooler_max / num_instances (ex: 60 / 2 = 30, arredondar pra 20 com folga).
#   Em Supabase Free tier (max 60 compartilhadas), usar 5 conservador.
# statement_timeout: cleanup server-side de queries órfãs (ms). Recomendado 5000.
#   Protege contra queries abandonadas por Promise.race dos health checks (Card 2.3).
DATABASE_URL="postgresql://postgres.{ref}:{password}@aws-1-sa-east-1.pooler.supabase.com:6543/postgres?pgbouncer=true&connection_limit=5&statement_timeout=5000"
# Conexão direta para migrations/schema push (porta 5432)
DIRECT_URL="postgresql://postgres:{password}@db.{ref}.supabase.co:5432/postgres"

# ===========================================
# Redis (Upstash - compartilhado com frontend - São Paulo)
# ===========================================
UPSTASH_REDIS_REST_URL="https://your-redis-url.upstash.io"
UPSTASH_REDIS_REST_TOKEN="your-redis-token"

# ===========================================
# Stripe (Billing)
# ===========================================
STRIPE_SECRET_KEY="sk_test_..."
STRIPE_WEBHOOK_SECRET="whsec_..."

# Price IDs por moeda (psychological pricing por mercado, sem conversão automática)
# BRL: R$29,90/mês | R$299,00/ano (2 meses grátis)
STRIPE_PRO_MONTHLY_BRL_PRICE_ID="price_..."
STRIPE_PRO_YEARLY_BRL_PRICE_ID="price_..."
# USD: $9.97/mo | $99.70/yr (2 months free)
STRIPE_PRO_MONTHLY_USD_PRICE_ID="price_..."
STRIPE_PRO_YEARLY_USD_PRICE_ID="price_..."
# EUR: €9,97/mês | €99,70/ano (2 meses grátis)
STRIPE_PRO_MONTHLY_EUR_PRICE_ID="price_..."
STRIPE_PRO_YEARLY_EUR_PRICE_ID="price_..."

# ===========================================
# Email (Resend - envio de tokens)
# ===========================================
EMAIL_PROVIDER="resend"
RESEND_API_KEY="re_..."
FROM_EMAIL="Tablix <noreply@tablix.com.br>"

# ===========================================
# JWT (Autenticacao - Session-backed)
# ===========================================
# Minimo 32 caracteres - gerar com: node -e "console.log(require('crypto').randomBytes(48).toString('base64url'))"
JWT_SECRET="GENERATE_ME"
# Access token curto (verificado em todo request)
JWT_ACCESS_TOKEN_EXPIRES_IN="15m"
# Refresh token longo (opaco, hash SHA-256 no DB, rotação a cada uso)
JWT_REFRESH_TOKEN_EXPIRES_IN="30d"

# ===========================================
# Frontend URL (CORS)
# ===========================================
FRONTEND_URL="http://localhost:3000"

# ===========================================
# Health checks (Card 2.3) — tunable sem rebuild
# ===========================================
# Timeouts dos health checks em ms. Defaults seguros; ajustar se
# Supabase/Upstash em região distante ou com cold start atípico.
HEALTH_TIMEOUT_DB_MS=1000
HEALTH_TIMEOUT_REDIS_MS=500
# TTL do cache stale-while-revalidate em ms. 2s amortiza probes
# sem mascarar falha real por mais que 1 ciclo (10s Fly.io default).
HEALTH_CACHE_TTL_MS=2000

# ===========================================
# Logging (Card 2.1)
# ===========================================
# Override opcional do nível de log. Default por NODE_ENV:
#   development → debug
#   production  → info
#   test        → fatal (silent)
# Valores aceitos: fatal | error | warn | info | debug | trace
LOG_LEVEL=

# ===========================================
# Sentry (error tracking + performance)
# ===========================================
# DSN do projeto tablix-back — gerar em sentry.io/settings/projects/tablix-back/keys/
# Técnicamente "public" (designed to be embedded), mas tratamos como config.
SENTRY_DSN=""
# development | staging | production (amarra com NODE_ENV no env.ts)
SENTRY_ENVIRONMENT="development"
# Commit SHA preenchido automaticamente no CI (Fase 9); vazio em dev é OK
SENTRY_RELEASE=""
# 0.0 = 0% tracing, 1.0 = 100%. Dev: 1.0, Staging: 0.5, Prod: 0.1
SENTRY_TRACES_SAMPLE_RATE="1.0"
# Profiling (Node.js profiler). Dev: 1.0, Prod: 0.1
SENTRY_PROFILES_SAMPLE_RATE="1.0"
# Auth token para upload de sourcemaps no CI (Fase 9). Scope: project:releases
# Gerar em sentry.io/settings/account/api/auth-tokens/
SENTRY_AUTH_TOKEN=""
SENTRY_ORG="tablix"
SENTRY_PROJECT="tablix-back"

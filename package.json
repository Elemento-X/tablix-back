{
  "name": "tablix-back-end",
  "version": "1.0.0",
  "description": "Backend do Tablix App",
  "engines": {
    "node": ">=20.0.0"
  },
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "lint": "eslint src --ext .ts --fix",
    "build": "npm run lint && npx prisma generate && tsc",
    "start": "node dist/src/server.js",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:unit": "vitest run tests/unit",
    "test:integration": "vitest run tests/integration",
    "test:coverage": "vitest run --coverage",
    "db:generate": "prisma generate",
    "db:migrate": "prisma migrate dev",
    "db:push": "prisma db push",
    "db:studio": "prisma studio",
    "db:seed": "tsx prisma/seed.ts"
  },
  "keywords": [
    "tablix",
    "planilhas",
    "csv",
    "unificador de planilhas"
  ],
  "author": "Lucas Camargo <contatolucasmaclean@gmail.com>",
  "license": "ISC",
  "dependencies": {
    "@fastify/cors": "^10.0.2",
    "@fastify/helmet": "^13.0.1",
    "@fastify/multipart": "^9.4.0",
    "@fastify/rate-limit": "^10.2.2",
    "@fastify/swagger": "^9.4.2",
    "@fastify/swagger-ui": "^5.2.1",
    "@prisma/client": "^6.19.2",
    "@sentry/node": "^10.48.0",
    "@sentry/profiling-node": "^10.48.0",
    "@upstash/ratelimit": "^2.0.8",
    "@upstash/redis": "^1.36.1",
    "axios": "^1.7.9",
    "body-parser": "^1.20.3",
    "cors": "^2.8.5",
    "dotenv": "^16.4.7",
    "fastify": "^5.2.1",
    "fastify-type-provider-zod": "^4.0.2",
    "jsonwebtoken": "^9.0.3",
    "papaparse": "^5.5.3",
    "prisma": "^6.19.2",
    "resend": "^6.7.0",
    "stripe": "^20.1.2",
    "xlsx": "0.18.5",
    "zod": "^3.24.1",
    "zod-to-json-schema": "^3.25.1"
  },
  "devDependencies": {
    "@rocketseat/eslint-config": "^2.2.2",
    "@types/cors": "^2.8.17",
    "@types/fastify-cors": "^0.1.0",
    "@types/jsonwebtoken": "^9.0.9",
    "@types/node": "^22.18.1",
    "@types/papaparse": "^5.5.2",
    "@types/supertest": "^6.0.3",
    "@vitest/coverage-istanbul": "^3.0.5",
    "eslint": "^8.57.1",
    "supertest": "^7.1.4",
    "ts-node": "^10.9.2",
    "tsx": "^4.19.2",
    "typescript": "^5.7.3",
    "vitest": "^3.2.4"
  }
}

// ===========================================
// TABLIX BACKEND - PRISMA SCHEMA
// ===========================================

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

// ===========================================
// USERS - Identidade do usuario
// ===========================================
// Entidade central de identidade, desacoplada de billing

model User {
  id                String    @id @default(uuid())
  email             String    @unique @db.VarChar(255)
  role              Role      @default(FREE)
  stripeCustomerId  String?   @unique @map("stripe_customer_id") @db.VarChar(255)
  createdAt         DateTime  @default(now()) @map("created_at")
  updatedAt         DateTime  @updatedAt @map("updated_at")

  // Relacionamentos
  tokens            Token[]
  sessions          Session[]
  usages            Usage[]
  jobs              Job[]

  @@map("users")
}

// ===========================================
// SESSIONS - Sessoes ativas do usuario
// ===========================================
// Cada login cria uma Session. JWT referencia session.id.
// Logout revoga a session (seta revokedAt).

model Session {
  id                String    @id @default(uuid())
  userId            String    @map("user_id")
  fingerprint       String?   @db.VarChar(64)
  userAgent         String?   @map("user_agent") @db.VarChar(512)
  ipAddress         String?   @map("ip_address") @db.VarChar(45)
  refreshTokenHash  String    @unique @map("refresh_token_hash") @db.VarChar(64)
  createdAt         DateTime  @default(now()) @map("created_at")
  lastActivityAt    DateTime  @default(now()) @map("last_activity_at")
  expiresAt         DateTime  @map("expires_at")
  revokedAt         DateTime? @map("revoked_at")

  // Relacionamento
  user              User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([expiresAt], map: "idx_sessions_expires_at")
  @@index([revokedAt], map: "idx_sessions_revoked_at")
  @@map("sessions")
}

// ===========================================
// TOKENS - Tokens de acesso Pro (ativacao)
// ===========================================
// Token gerado apos pagamento no Stripe, enviado por email.
// Mecanismo de ativacao, nao identidade.

model Token {
  id                    String      @id @default(uuid())
  userId                String      @map("user_id")
  token                 String      @unique @db.VarChar(64)
  fingerprint           String?     @db.VarChar(64)
  stripeSubscriptionId  String?     @map("stripe_subscription_id") @db.VarChar(255)
  plan                  Plan        @default(PRO)
  status                TokenStatus @default(ACTIVE)
  createdAt             DateTime    @default(now()) @map("created_at")
  activatedAt           DateTime?   @map("activated_at")
  expiresAt             DateTime?   @map("expires_at")

  // Relacionamento — RESTRICT: cancelar subscription antes de deletar user
  user                  User        @relation(fields: [userId], references: [id], onDelete: Restrict)

  @@unique([userId, stripeSubscriptionId], map: "uq_tokens_user_subscription")
  @@index([token])
  @@index([fingerprint])
  @@index([userId], map: "idx_tokens_user")
  @@map("tokens")
}

// ===========================================
// USAGE - Uso mensal (para limites do plano)
// ===========================================
// Controla quantas unificacoes o usuario fez no mes

model Usage {
  id                String   @id @default(uuid())
  userId            String   @map("user_id")
  period            String   @db.VarChar(7) // Formato: 'YYYY-MM'
  unificationsCount Int      @default(0) @map("unifications_count")
  createdAt         DateTime @default(now()) @map("created_at")

  // Relacionamento — RESTRICT: preservar historico de billing
  user              User     @relation(fields: [userId], references: [id], onDelete: Restrict)

  @@unique([userId, period])
  @@map("usage")
}

// ===========================================
// JOBS - Jobs de processamento assincrono
// ===========================================
// Para arquivos >10MB que precisam de processamento em fila

model Job {
  id              String    @id @default(uuid())
  userId          String    @map("user_id")
  status          JobStatus @default(PENDING)
  inputFiles      Json      @map("input_files")
  outputFileUrl   String?   @map("output_file_url") @db.VarChar(500)
  errorMessage    String?   @map("error_message")
  createdAt       DateTime  @default(now()) @map("created_at")
  startedAt       DateTime? @map("started_at")
  completedAt     DateTime? @map("completed_at")

  // Relacionamento
  user            User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId], map: "idx_jobs_user")
  @@index([status], map: "idx_jobs_status")
  @@map("jobs")
}

// ===========================================
// STRIPE EVENTS - Idempotencia de webhooks
// ===========================================
// Registra event.id processados para deduplicacao.
// Insert duplicado gera P2002 (unique violation) = evento ja processado.

model StripeEvent {
  id          String   @id @db.VarChar(255) // event.id do Stripe (evt_...)
  type        String   @db.VarChar(255)
  processedAt DateTime @default(now()) @map("processed_at") @db.Timestamptz(3)

  @@index([processedAt], map: "idx_stripe_events_processed_at")
  @@map("stripe_events")
}

// ===========================================
// ENUMS
// ===========================================

enum Role {
  FREE
  PRO
}

enum Plan {
  PRO
}

enum TokenStatus {
  ACTIVE
  CANCELLED
  EXPIRED
}

enum JobStatus {
  PENDING
  PROCESSING
  COMPLETED
  FAILED
}
